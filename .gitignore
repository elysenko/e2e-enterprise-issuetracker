# Dependencies — regenerated by `npm ci` during the deploy build; never committed.
node_modules/

# Build output — regenerated by `npm run build` during the deploy build.
dist/
out-tsc/
/tmp/

# TypeScript incremental build cache — poisons `nest build` if shipped.
*.tsbuildinfo

# Angular build cache
.angular/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS noise
.DS_Store
*.swp

# Local environment files — hold live credentials; injected at deploy time, never committed.
.env
.env.*
!.env.example
